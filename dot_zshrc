# ~/.zshrc

# Over SSH, fall back to xterm-256color if the forwarded TERM has no terminfo entry on this machine
if [[ -z "$TERM" ]] || { [[ -n "$SSH_CONNECTION" ]] && ! infocmp "$TERM" &>/dev/null; }; then
  export TERM=xterm-256color
fi

# Key bindings
bindkey -e                        # Emacs key bindings (default for most terminals)
bindkey "^?" backward-delete-char # Backspace
bindkey "^H" backward-delete-char # Backspace (alternative)
bindkey "^[[3~" delete-char       # Delete key
bindkey "^[[H" beginning-of-line  # Home
bindkey "^[[F" end-of-line        # End

# Homebrew (Linux)
if [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Starship prompt
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi

# Zinit plugin manager
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
  mkdir -p "$(dirname "$ZINIT_HOME")"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

# Plugins — zsh-completions must come before compinit, syntax-highlighting last
zinit light zsh-users/zsh-completions
autoload -Uz compinit && compinit
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting

# zoxide (smart cd)
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

# fzf (fuzzy finder — Ctrl+R, Ctrl+T, Alt+C)
if command -v fzf &>/dev/null; then
  eval "$(fzf --zsh)"
fi

# eza (modern ls)
if command -v eza &>/dev/null; then
  alias ls='eza'
  alias ll='eza -la'
  alias tree='eza --tree'
fi
